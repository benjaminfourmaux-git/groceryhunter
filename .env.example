# Copiez ce fichier en `.env` et remplissez les valeurs.
# Ces 3 variables sont publiques (préfixe VITE_) : elles sont incluses dans le build.

# Tableau de bord Supabase > Project Settings > API
VITE_SUPABASE_URL=https://VOTRE-PROJET.supabase.co
VITE_SUPABASE_ANON_KEY=votre-cle-anon-publique

# Clé VAPID PUBLIQUE pour les notifications Web Push (voir README, étape 4)
VITE_VAPID_PUBLIC_KEY=votre-cle-vapid-publique
